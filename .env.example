DATABASE_URL=postgresql://shiftcraft:shiftcraft@localhost:5432/shiftcraft
SECRET_KEY=change-me-to-a-random-32-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
SENTRY_DSN=

# App URL (used in password reset emails)
APP_URL=http://127.0.0.1:8000

# SMTP email — leave SMTP_HOST empty to print reset links to the terminal instead
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=ShiftCraft <you@gmail.com>
